# Server
PORT=4000

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/thrift_solution

# Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this

# Dashboard URL (for payment callbacks and webhooks)
DASHBOARD_URL=http://localhost:3001

# API URL (backend public URL, used in webhooks)
API_URL=http://localhost:4000

# Payment Providers
PAYSTACK_SECRET_KEY=sk_test_xxxxx
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-xxxxx
# Webhook Secret Hash set in Flutterwave dashboard (Settings > Webhooks).
# Sent verbatim in the `verif-hash` header and used to verify incoming webhooks.
# If empty, the handler falls back to verifying with FLUTTERWAVE_SECRET_KEY.
FLUTTERWAVE_WEBHOOK_SECRET=
NOMBA_API_KEY=xxxxx
NOMBA_MERCHANT_ID=xxxxx

# Virtual Account Auto-Generation Job
# Which provider to use for auto-generated accounts: flutterwave | paystack | nomba
DEFAULT_VIRTUAL_ACCOUNT_PROVIDER=flutterwave

# Registration 3-step flow
# Which provider to use for the one-time registration fee: flutterwave | paystack | nomba
REGISTRATION_PAYMENT_PROVIDER=flutterwave
# One-time registration fee in NGN (default 4200)
REGISTRATION_FEE_NGN=4200

# CreditChek (KYC identity + credit report)
CREDITCHEK_SECRET_KEY=your-creditchek-secret-key
CREDITCHEK_BASE_URL=https://api.creditchek.africa

# Image Upload (choose one provider)
# Options: supabase | cloudinary | s3 | local
IMAGE_UPLOAD_PROVIDER=local

# Local uploads (default)
LOCAL_UPLOAD_DIR=./uploads
LOCAL_BASE_URL=http://localhost:4000

# Supabase (if using supabase provider)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_BUCKET=images

# Cloudinary (if using cloudinary provider)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=

# AWS S3 (if using s3 provider)
AWS_S3_REGION=
AWS_S3_BUCKET=
AWS_S3_ACCESS_KEY_ID=
AWS_S3_SECRET_ACCESS_KEY=
AWS_S3_ENDPOINT=
AWS_S3_FORCE_PATH_STYLE=false

# Image Compression (optional)
IMAGE_COMPRESSION_ENABLED=true
IMAGE_COMPRESSION_QUALITY=80
IMAGE_COMPRESSION_MAX_WIDTH=1920
IMAGE_COMPRESSION_MAX_HEIGHT=1080
IMAGE_COMPRESSION_FORMAT=webp

# Image Fallback (optional - use a secondary provider if primary fails)
IMAGE_FALLBACK_ENABLED=false
IMAGE_FALLBACK_PROVIDER=local

# Notifications
# In-app notifications are stored in the database and always enabled per-user preference.
# Email (ZeptoMail) and SMS (Termii) are sent based on each user's notification preferences.

# Email (ZeptoMail)
ZEPTOMAIL_TOKEN=
ZEPTOMAIL_FROM=admin@lumenware.com.ng
ZEPTOMAIL_FROM_NAME=APM Campaign

# SMS (Termii)
TERMII_API_KEY=
TERMII_SENDER_ID=StringsApp
TERMII_BASE_URL=https://v3.api.termii.com/api

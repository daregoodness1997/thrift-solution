generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Config {
  id        String    @id @default("default")
  data      String    @db.Text
  deletedAt DateTime? @map("deleted_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @default(now()) @updatedAt @map("updated_at")

  @@map("configs")
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  name          String
  passwordHash  String    @map("password_hash")
  role          String    @default("member")
  accountNumber String    @unique @map("account_number")
  accountTier   String    @default("basic") @map("account_tier")
  referralCode  String    @unique @map("referral_code")
  referredBy    String?   @map("referred_by")
  phone         String?   @map("phone")
  emailVerified   Boolean   @default(false) @map("email_verified")
  emailVerifiedAt DateTime? @map("email_verified_at")
  phoneVerified   Boolean   @default(false) @map("phone_verified")
  phoneVerifiedAt DateTime? @map("phone_verified_at")
  totpSecret      String?   @map("totp_secret")
  twoFactorEnabled Boolean  @default(false) @map("two_factor_enabled")
  bvn             String?   @map("bvn")
  nin             String?   @map("nin")
  registrationStep Int       @default(1) @map("registration_step")
  registrationFeePaid Boolean @default(false) @map("registration_fee_paid")
  registrationCompletedAt DateTime? @map("registration_completed_at")
  deletedAt     DateTime? @map("deleted_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @default(now()) @updatedAt @map("updated_at")

  donations              Donation[]
  transactions           Transaction[]
  groupMembers           GroupMember[]
  referrals              Referral[]          @relation("Referrer")
  referralEarnings       ReferralEarning[]
  kyc                    Kyc?
  conversationMembers    ConversationMember[]
  sentMessages           Message[]
  whatsappGroupMembers   WhatsappGroupMember[]
  marketplaceListings    MarketplaceListing[]
  marketplaceOffers      MarketplaceOffer[]  @relation("Offerer")
  jobListings            JobListing[]
  jobApplications        JobApplication[]    @relation("Applicant")
  loans                  Loan[]              @relation("Borrower")
  circleAccounts         CircleAccount[]
  circlePayoutRequests   CirclePayoutRequest[] @relation("CirclePayoutRequestUser")
  reviewedPayoutRequests CirclePayoutRequest[] @relation("ReviewedBy")
  virtualAccounts        VirtualAccount[]
  auditLogs              AuditLog[]          @relation("AuditActor")
  notifications          Notification[]
  notificationPreferences NotificationPreference?
  verificationTokens      VerificationToken[]

  @@map("users")
}

model AuditLog {
  id         String   @id @default(uuid())
  actorId    String?  @map("actor_id")
  actorEmail String?  @map("actor_email")
  action     String
  entity     String
  entityId   String?  @map("entity_id")
  metadata   String?  @db.Text
  ipAddress  String?  @map("ip_address")
  createdAt  DateTime @default(now()) @map("created_at")

  actor User? @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([actorId])
  @@index([entity])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

model Group {
  id              String    @id @default(uuid())
  name            String
  description     String?
  targetAmount    Float     @map("target_amount")
  currentAmount   Float     @default(0) @map("current_amount")
  memberCount     Int       @default(0) @map("member_count")
  cycleFrequency  String    @map("cycle_frequency")
  status          String    @default("active")
  deletedAt       DateTime? @map("deleted_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @default(now()) @updatedAt @map("updated_at")

  members   GroupMember[]
  donations Donation[]

  @@map("groups")
}

model GroupMember {
  id        String    @id @default(uuid())
  groupId   String    @map("group_id")
  userId    String    @map("user_id")
  role      String    @default("member")
  deletedAt DateTime? @map("deleted_at")
  joinedAt  DateTime  @default(now()) @map("joined_at")

  group Group @relation(fields: [groupId], references: [id], onDelete: Restrict)
  user  User  @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@unique([groupId, userId])
  @@map("group_members")
}

model Donation {
  id                String    @id @default(uuid())
  userId            String    @map("user_id")
  type              String
  amount            Float?
  currency          String    @default("NGN")
  itemName          String?   @map("item_name")
  itemDescription   String?   @map("item_description")
  itemImage         String?   @map("item_image")
  itemCategory      String?   @map("item_category")
  itemCondition     String?   @map("item_condition")
  status            String    @default("pending")
  paymentProvider   String?   @map("payment_provider")
  paymentReference  String?   @map("payment_reference")
  paymentUrl        String?   @map("payment_url")
  groupId           String?   @map("group_id")
  notes             String?
  deletedAt         DateTime? @map("deleted_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @default(now()) @updatedAt @map("updated_at")

  user  User   @relation(fields: [userId], references: [id], onDelete: Restrict)
  group Group? @relation(fields: [groupId], references: [id], onDelete: SetNull)

  transactions Transaction[]

  @@index([userId])
  @@index([groupId])
  @@index([paymentReference])
  @@map("donations")
}

model Transaction {
  id           String    @id @default(uuid())
  userId       String    @map("user_id")
  type         String
  amount       Float
  groupId      String?   @map("group_id")
  donationId   String?   @map("donation_id")
  reference    String    @unique
  status       String    @default("pending")
  description  String?
  deletedAt    DateTime? @map("deleted_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  user     User      @relation(fields: [userId], references: [id], onDelete: Restrict)
  donation Donation? @relation(fields: [donationId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@map("transactions")
}

model Referral {
  id             String    @id @default(uuid())
  referrerId     String    @map("referrer_id")
  referredUserId String    @map("referred_user_id")
  status         String    @default("pending")
  deletedAt      DateTime? @map("deleted_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  referrer User               @relation("Referrer", fields: [referrerId], references: [id], onDelete: Restrict)
  earnings ReferralEarning[]

  @@unique([referrerId, referredUserId])
  @@index([referrerId])
  @@map("referrals")
}

model ReferralEarning {
  id          String    @id @default(uuid())
  referralId  String    @map("referral_id")
  referrerId  String    @map("referrer_id")
  tier        String
  amount      Float
  status      String    @default("pending")
  deletedAt   DateTime? @map("deleted_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  referral Referral @relation(fields: [referralId], references: [id], onDelete: Restrict)
  referrer User     @relation(fields: [referrerId], references: [id], onDelete: Restrict)

  @@index([referrerId])
  @@map("referral_earnings")
}

model Kyc {
  id              String    @id @default(uuid())
  userId          String    @unique @map("user_id")
  level           Int       @default(1)
  idType          String    @map("id_type")
  idNumber        String    @map("id_number")
  bvn             String?   @map("bvn")
  nin             String?   @map("nin")
  verifiedName    String?   @map("verified_name")
  creditReport    Json?     @map("credit_report")
  verificationData Json?     @map("verification_data")
  idDocumentUrl   String?   @map("id_document_url")
  selfieUrl       String?   @map("selfie_url")
  status          String    @default("pending")
  rejectionReason String?   @map("rejection_reason")
  reviewedBy      String?   @map("reviewed_by")
  verifiedAt      DateTime? @map("verified_at")
  submittedAt     DateTime  @default(now()) @map("submitted_at")
  deletedAt       DateTime? @map("deleted_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @default(now()) @updatedAt @map("updated_at")

  user       User           @relation(fields: [userId], references: [id], onDelete: Restrict)
  documents  KycDocument[]
  auditLogs  KycAuditLog[]

  @@index([userId])
  @@index([status])
  @@map("kyc")
}

model KycDocument {
  id          String    @id @default(uuid())
  kycId       String    @map("kyc_id")
  fileUrl     String    @map("file_url")
  fileType    String    @map("file_type")
  fileName    String    @map("file_name")
  fileSize    Int       @map("file_size")
  purpose     String    @default("id_document")
  deletedAt   DateTime? @map("deleted_at")
  uploadedAt  DateTime  @default(now()) @map("uploaded_at")

  kyc Kyc @relation(fields: [kycId], references: [id], onDelete: Restrict)

  @@index([kycId])
  @@map("kyc_documents")
}

model KycAuditLog {
  id          String    @id @default(uuid())
  kycId       String    @map("kyc_id")
  action      String
  oldStatus   String?   @map("old_status")
  newStatus   String?   @map("new_status")
  notes       String?
  performedBy String?   @map("performed_by")
  deletedAt   DateTime? @map("deleted_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  kyc Kyc @relation(fields: [kycId], references: [id], onDelete: Restrict)

  @@index([kycId])
  @@index([createdAt])
  @@map("kyc_audit_logs")
}

model Conversation {
  id        String    @id @default(uuid())
  name      String?
  deletedAt DateTime? @map("deleted_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @default(now()) @updatedAt @map("updated_at")

  members ConversationMember[]
  messages Message[]

  @@map("conversations")
}

model ConversationMember {
  id             String    @id @default(uuid())
  conversationId String    @map("conversation_id")
  userId         String    @map("user_id")
  deletedAt      DateTime? @map("deleted_at")
  joinedAt       DateTime  @default(now()) @map("joined_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Restrict)
  user         User         @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@unique([conversationId, userId])
  @@map("conversation_members")
}

model Message {
  id             String    @id @default(uuid())
  conversationId String    @map("conversation_id")
  senderId       String    @map("sender_id")
  text           String
  deletedAt      DateTime? @map("deleted_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Restrict)
  sender       User         @relation(fields: [senderId], references: [id], onDelete: Restrict)

  @@index([conversationId])
  @@index([senderId])
  @@map("messages")
}

model WhatsappGroup {
  id          String    @id @default(uuid())
  name        String
  description String?
  circleName  String?   @map("circle_name")
  inviteLink  String?   @map("invite_link")
  memberCount Int       @default(0) @map("member_count")
  pinned      Boolean   @default(false)
  deletedAt   DateTime? @map("deleted_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at")

  members WhatsappGroupMember[]

  @@map("whatsapp_groups")
}

model WhatsappGroupMember {
  id        String    @id @default(uuid())
  groupId   String    @map("group_id")
  userId    String    @map("user_id")
  deletedAt DateTime? @map("deleted_at")
  joinedAt  DateTime  @default(now()) @map("joined_at")

  group WhatsappGroup @relation(fields: [groupId], references: [id], onDelete: Restrict)
  user  User          @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@unique([groupId, userId])
  @@map("whatsapp_group_members")
}

model MarketplaceListing {
  id          String    @id @default(uuid())
  sellerId    String    @map("seller_id")
  title       String
  description String    @db.Text
  price       Float
  currency    String    @default("NGN")
  category    String
  condition   String
  imageUrl    String?   @map("image_url")
  status      String    @default("active")
  deletedAt   DateTime? @map("deleted_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at")

  seller User               @relation(fields: [sellerId], references: [id], onDelete: Restrict)
  offers MarketplaceOffer[]

  @@index([sellerId])
  @@index([status])
  @@index([category])
  @@map("marketplace_listings")
}

model MarketplaceOffer {
  id         String    @id @default(uuid())
  listingId  String    @map("listing_id")
  offererId  String    @map("offerer_id")
  amount     Float
  message    String?
  status     String    @default("pending")
  deletedAt  DateTime? @map("deleted_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @default(now()) @updatedAt @map("updated_at")

  listing MarketplaceListing @relation(fields: [listingId], references: [id], onDelete: Restrict)
  offerer User               @relation("Offerer", fields: [offererId], references: [id], onDelete: Restrict)

  @@index([listingId])
  @@index([offererId])
  @@map("marketplace_offers")
}

model JobListing {
  id          String    @id @default(uuid())
  posterId    String    @map("poster_id")
  title       String
  description String    @db.Text
  company     String?
  location    String
  jobType     String    @map("job_type")
  salaryMin   Float?    @map("salary_min")
  salaryMax   Float?    @map("salary_max")
  currency    String    @default("NGN")
  category    String
  status      String    @default("active")
  deletedAt   DateTime? @map("deleted_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at")

  poster       User             @relation(fields: [posterId], references: [id], onDelete: Restrict)
  applications JobApplication[]

  @@index([posterId])
  @@index([status])
  @@index([category])
  @@index([jobType])
  @@map("job_listings")
}

model JobApplication {
  id          String    @id @default(uuid())
  listingId   String    @map("listing_id")
  applicantId String    @map("applicant_id")
  resumeUrl   String?   @map("resume_url")
  coverLetter String?   @db.Text
  status      String    @default("pending")
  deletedAt   DateTime? @map("deleted_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at")

  listing   JobListing @relation(fields: [listingId], references: [id], onDelete: Restrict)
  applicant User       @relation("Applicant", fields: [applicantId], references: [id], onDelete: Restrict)

  @@unique([listingId, applicantId])
  @@index([listingId])
  @@index([applicantId])
  @@map("job_applications")
}

model Loan {
  id             String    @id @default(uuid())
  borrowerId     String    @map("borrower_id")
  amount         Float
  interestRate   Float     @map("interest_rate")
  termMonths     Int       @map("term_months")
  monthlyPayment Float     @map("monthly_payment")
  totalRepayment Float     @map("total_repayment")
  purpose        String?
  status         String    @default("pending")
  approvedAt     DateTime? @map("approved_at")
  disbursedAt    DateTime? @map("disbursed_at")
  completedAt    DateTime? @map("completed_at")
  deletedAt      DateTime? @map("deleted_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @default(now()) @updatedAt @map("updated_at")

  borrower User @relation("Borrower", fields: [borrowerId], references: [id], onDelete: Restrict)

  @@index([borrowerId])
  @@index([status])
  @@map("loans")
}

model Circle {
  id                  String    @id @default(uuid())
  name                String
  description         String?
  amount              Float
  durationMonths      Int       @map("duration_months")
  interestRateAnnual  Float     @map("interest_rate_annual")
  maxAccountsPerUser  Int       @default(10) @map("max_accounts_per_user")
  autoPayout          Boolean   @default(false) @map("auto_payout")
  status              String    @default("active")
  deletedAt           DateTime? @map("deleted_at")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @default(now()) @updatedAt @map("updated_at")

  accounts CircleAccount[]

  @@map("circles")
}

model CircleAccount {
  id                        String    @id @default(uuid())
  circleId                  String    @map("circle_id")
  userId                    String    @map("user_id")
  principalAmount           Float     @map("principal_amount")
  interestEarned            Float     @default(0) @map("interest_earned")
  totalWithdrawn            Float     @default(0) @map("total_withdrawn")
  status                    String    @default("active")
  startDate                 DateTime  @map("start_date")
  maturityDate              DateTime  @map("maturity_date")
  lastInterestCalculation   DateTime? @map("last_interest_calculation")
  deletedAt                 DateTime? @map("deleted_at")
  createdAt                 DateTime  @default(now()) @map("created_at")
  updatedAt                 DateTime  @default(now()) @updatedAt @map("updated_at")

  circle        Circle                @relation(fields: [circleId], references: [id], onDelete: Restrict)
  user          User                  @relation(fields: [userId], references: [id], onDelete: Restrict)
  interestLogs  CircleInterestLog[]
  payoutRequests CirclePayoutRequest[]

  @@index([circleId])
  @@index([userId])
  @@index([status])
  @@map("circle_accounts")
}

model CircleInterestLog {
  id                      String    @id @default(uuid())
  circleAccountId         String    @map("circle_account_id")
  amount                  Float
  principalAtCalculation  Float     @map("principal_at_calculation")
  annualRate              Float     @map("annual_rate")
  deletedAt               DateTime? @map("deleted_at")
  calculatedAt            DateTime  @default(now()) @map("calculated_at")

  circleAccount CircleAccount @relation(fields: [circleAccountId], references: [id], onDelete: Restrict)

  @@index([circleAccountId])
  @@index([calculatedAt])
  @@map("circle_interest_logs")
}

model CirclePayoutRequest {
  id              String    @id @default(uuid())
  circleAccountId String    @map("circle_account_id")
  userId          String    @map("user_id")
  amount          Float
  status          String    @default("pending")
  note            String?
  reviewedById    String?   @map("reviewed_by_id")
  reviewedAt      DateTime? @map("reviewed_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @default(now()) @updatedAt @map("updated_at")

  circleAccount CircleAccount @relation(fields: [circleAccountId], references: [id], onDelete: Restrict)
  user          User           @relation("CirclePayoutRequestUser", fields: [userId], references: [id], onDelete: Restrict)
  reviewedBy    User?          @relation("ReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([circleAccountId])
  @@index([userId])
  @@index([status])
  @@map("circle_payout_requests")
}

model NavigationItem {
  id        String    @id @default(uuid())
  label     String
  href      String
  icon      String    @db.Text
  badge     String?
  section   String    @default("")
  sortOrder Int       @default(0) @map("sort_order")
  isActive  Boolean   @default(true) @map("is_active")
  deletedAt DateTime? @map("deleted_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @default(now()) @updatedAt @map("updated_at")

  roles RoleNavigation[]

  @@unique([href])
  @@map("navigation_items")
}

model RoleNavigation {
  id               String    @id @default(uuid())
  role             String
  navigationItemId String    @map("navigation_item_id")
  sortOrder        Int       @default(0) @map("sort_order")
  deletedAt        DateTime? @map("deleted_at")
  createdAt        DateTime  @default(now()) @map("created_at")

  navigationItem NavigationItem @relation(fields: [navigationItemId], references: [id], onDelete: Restrict)

  @@unique([role, navigationItemId])
  @@index([role])
  @@map("role_navigation")
}

model VirtualAccount {
  id                String    @id @default(uuid())
  userId            String    @map("user_id")
  provider          String
  accountNumber     String    @map("account_number")
  bankName          String    @map("bank_name")
  bankCode          String?   @map("bank_code")
  currency          String    @default("NGN")
  reference         String    @unique
  providerRef       String?   @unique @map("provider_ref")
  isPermanent       Boolean   @default(true) @map("is_permanent")
  bvn               String?
  nin               String?
  accountName       String?   @map("account_name")
  status            String    @default("active")
  lastTransferAt    DateTime? @map("last_transfer_at")
  deletedAt         DateTime? @map("deleted_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @default(now()) @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([provider])
  @@index([accountNumber])
  @@map("virtual_accounts")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  type      String
  title     String
  body      String   @db.Text
  data      String?  @db.Text
  channel   String   @default("in_app") @map("channel")
  status    String   @default("unread") @map("status")
  readAt    DateTime? @map("read_at")
  deletedAt DateTime? @map("deleted_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, status])
  @@index([createdAt])
  @@map("notifications")
}

model NotificationPreference {
  id        String   @id @default(uuid())
  userId    String   @unique @map("user_id")
  inApp     Boolean  @default(true) @map("in_app")
  email     Boolean  @default(true)
  sms       Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_preferences")
}

model VerificationToken {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  type        String
  channel     String    @map("channel")
  destination String?   @map("destination")
  code        String
  expiresAt   DateTime  @map("expires_at")
  consumedAt  DateTime? @map("consumed_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([code])
  @@map("verification_tokens")
}

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Config {
  id        String   @id @default("default")
  data      String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("configs")
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  name          String
  passwordHash  String   @map("password_hash")
  role          String   @default("member")
  accountNumber String   @unique @map("account_number")
  accountTier   String   @default("basic") @map("account_tier")
  referralCode  String   @unique @map("referral_code")
  referredBy    String?  @map("referred_by")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at")

  donations              Donation[]
  transactions           Transaction[]
  groupMembers           GroupMember[]
  referrals              Referral[]          @relation("Referrer")
  referralEarnings       ReferralEarning[]
  kyc                    Kyc?
  conversationMembers    ConversationMember[]
  sentMessages           Message[]
  whatsappGroupMembers   WhatsappGroupMember[]
  marketplaceListings    MarketplaceListing[]
  marketplaceOffers      MarketplaceOffer[]  @relation("Offerer")
  jobListings            JobListing[]
  jobApplications        JobApplication[]    @relation("Applicant")
  loans                  Loan[]              @relation("Borrower")

  @@map("users")
}

model Group {
  id              String   @id @default(uuid())
  name            String
  description     String?
  targetAmount    Float    @map("target_amount")
  currentAmount   Float    @default(0) @map("current_amount")
  memberCount     Int      @default(0) @map("member_count")
  cycleFrequency  String   @map("cycle_frequency")
  status          String   @default("active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at")

  members   GroupMember[]
  donations Donation[]

  @@map("groups")
}

model GroupMember {
  id       String   @id @default(uuid())
  groupId  String   @map("group_id")
  userId   String   @map("user_id")
  role     String   @default("member")
  joinedAt DateTime @default(now()) @map("joined_at")

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@map("group_members")
}

model Donation {
  id                String   @id @default(uuid())
  userId            String   @map("user_id")
  type              String
  amount            Float?
  currency          String   @default("NGN")
  itemName          String?  @map("item_name")
  itemDescription   String?  @map("item_description")
  itemImage         String?  @map("item_image")
  itemCategory      String?  @map("item_category")
  itemCondition     String?  @map("item_condition")
  status            String   @default("pending")
  paymentProvider   String?  @map("payment_provider")
  paymentReference  String?  @map("payment_reference")
  paymentUrl        String?  @map("payment_url")
  groupId           String?  @map("group_id")
  notes             String?
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @default(now()) @updatedAt @map("updated_at")

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  group Group? @relation(fields: [groupId], references: [id], onDelete: SetNull)

  transactions Transaction[]

  @@index([userId])
  @@index([groupId])
  @@index([paymentReference])
  @@map("donations")
}

model Transaction {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  type         String
  amount       Float
  groupId      String?  @map("group_id")
  donationId   String?  @map("donation_id")
  reference    String   @unique
  status       String   @default("pending")
  description  String?
  createdAt    DateTime @default(now()) @map("created_at")

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  donation Donation? @relation(fields: [donationId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@map("transactions")
}

model Referral {
  id             String   @id @default(uuid())
  referrerId     String   @map("referrer_id")
  referredUserId String   @map("referred_user_id")
  status         String   @default("pending")
  createdAt      DateTime @default(now()) @map("created_at")

  referrer User               @relation("Referrer", fields: [referrerId], references: [id], onDelete: Cascade)
  earnings ReferralEarning[]

  @@unique([referrerId, referredUserId])
  @@index([referrerId])
  @@map("referrals")
}

model ReferralEarning {
  id          String   @id @default(uuid())
  referralId  String   @map("referral_id")
  referrerId  String   @map("referrer_id")
  tier        String
  amount      Float
  status      String   @default("pending")
  createdAt   DateTime @default(now()) @map("created_at")

  referral Referral @relation(fields: [referralId], references: [id], onDelete: Cascade)
  referrer User     @relation(fields: [referrerId], references: [id], onDelete: Cascade)

  @@index([referrerId])
  @@map("referral_earnings")
}

model Kyc {
  id              String   @id @default(uuid())
  userId          String   @unique @map("user_id")
  idType          String   @map("id_type")
  idNumber        String   @map("id_number")
  idDocumentUrl   String?  @map("id_document_url")
  selfieUrl       String?  @map("selfie_url")
  status          String   @default("pending")
  rejectionReason String?  @map("rejection_reason")
  reviewedBy      String?  @map("reviewed_by")
  verifiedAt      DateTime? @map("verified_at")
  submittedAt     DateTime @default(now()) @map("submitted_at")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at")

  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  documents  KycDocument[]
  auditLogs  KycAuditLog[]

  @@index([userId])
  @@index([status])
  @@map("kyc")
}

model KycDocument {
  id          String   @id @default(uuid())
  kycId       String   @map("kyc_id")
  fileUrl     String   @map("file_url")
  fileType    String   @map("file_type")
  fileName    String   @map("file_name")
  fileSize    Int      @map("file_size")
  purpose     String   @default("id_document")
  uploadedAt  DateTime @default(now()) @map("uploaded_at")

  kyc Kyc @relation(fields: [kycId], references: [id], onDelete: Cascade)

  @@index([kycId])
  @@map("kyc_documents")
}

model KycAuditLog {
  id          String   @id @default(uuid())
  kycId       String   @map("kyc_id")
  action      String
  oldStatus   String?  @map("old_status")
  newStatus   String?  @map("new_status")
  notes       String?
  performedBy String?  @map("performed_by")
  createdAt   DateTime @default(now()) @map("created_at")

  kyc Kyc @relation(fields: [kycId], references: [id], onDelete: Cascade)

  @@index([kycId])
  @@index([createdAt])
  @@map("kyc_audit_logs")
}

model Conversation {
  id        String   @id @default(uuid())
  name      String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  members ConversationMember[]
  messages Message[]

  @@map("conversations")
}

model ConversationMember {
  id             String   @id @default(uuid())
  conversationId String   @map("conversation_id")
  userId         String   @map("user_id")
  joinedAt       DateTime @default(now()) @map("joined_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@map("conversation_members")
}

model Message {
  id             String   @id @default(uuid())
  conversationId String   @map("conversation_id")
  senderId       String   @map("sender_id")
  text           String
  createdAt      DateTime @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([senderId])
  @@map("messages")
}

model WhatsappGroup {
  id          String   @id @default(uuid())
  name        String
  description String?
  circleName  String?  @map("circle_name")
  inviteLink  String?  @map("invite_link")
  memberCount Int      @default(0) @map("member_count")
  pinned      Boolean  @default(false)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")

  members WhatsappGroupMember[]

  @@map("whatsapp_groups")
}

model WhatsappGroupMember {
  id        String   @id @default(uuid())
  groupId   String   @map("group_id")
  userId    String   @map("user_id")
  joinedAt  DateTime @default(now()) @map("joined_at")

  group WhatsappGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@map("whatsapp_group_members")
}

model MarketplaceListing {
  id          String   @id @default(uuid())
  sellerId    String   @map("seller_id")
  title       String
  description String   @db.Text
  price       Float
  currency    String   @default("NGN")
  category    String
  condition   String
  imageUrl    String?  @map("image_url")
  status      String   @default("active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")

  seller User               @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  offers MarketplaceOffer[]

  @@index([sellerId])
  @@index([status])
  @@index([category])
  @@map("marketplace_listings")
}

model MarketplaceOffer {
  id         String   @id @default(uuid())
  listingId  String   @map("listing_id")
  offererId  String   @map("offerer_id")
  amount     Float
  message    String?
  status     String   @default("pending")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at")

  listing MarketplaceListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  offerer User               @relation("Offerer", fields: [offererId], references: [id], onDelete: Cascade)

  @@index([listingId])
  @@index([offererId])
  @@map("marketplace_offers")
}

model JobListing {
  id          String   @id @default(uuid())
  posterId    String   @map("poster_id")
  title       String
  description String   @db.Text
  company     String?
  location    String
  jobType     String   @map("job_type")
  salaryMin   Float?   @map("salary_min")
  salaryMax   Float?   @map("salary_max")
  currency    String   @default("NGN")
  category    String
  status      String   @default("active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")

  poster       User             @relation(fields: [posterId], references: [id], onDelete: Cascade)
  applications JobApplication[]

  @@index([posterId])
  @@index([status])
  @@index([category])
  @@index([jobType])
  @@map("job_listings")
}

model JobApplication {
  id          String   @id @default(uuid())
  listingId   String   @map("listing_id")
  applicantId String   @map("applicant_id")
  resumeUrl   String?  @map("resume_url")
  coverLetter String?  @db.Text
  status      String   @default("pending")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")

  listing   JobListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  applicant User       @relation("Applicant", fields: [applicantId], references: [id], onDelete: Cascade)

  @@unique([listingId, applicantId])
  @@index([listingId])
  @@index([applicantId])
  @@map("job_applications")
}

model Loan {
  id             String   @id @default(uuid())
  borrowerId     String   @map("borrower_id")
  amount         Float
  interestRate   Float    @map("interest_rate")
  termMonths     Int      @map("term_months")
  monthlyPayment Float    @map("monthly_payment")
  totalRepayment Float    @map("total_repayment")
  purpose        String?
  status         String   @default("pending")
  approvedAt     DateTime? @map("approved_at")
  disbursedAt    DateTime? @map("disbursed_at")
  completedAt    DateTime? @map("completed_at")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at")

  borrower User @relation("Borrower", fields: [borrowerId], references: [id], onDelete: Cascade)

  @@index([borrowerId])
  @@index([status])
  @@map("loans")
}

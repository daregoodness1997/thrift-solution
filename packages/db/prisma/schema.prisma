generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Config {
  id        String    @id @default("default")
  data      String
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @default(now()) @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@map("configs")
}

model User {
  id                      String                  @id @default(uuid())
  email                   String                  @unique
  name                    String
  passwordHash            String                  @map("password_hash")
  role                    String                  @default("member")
  referralCode            String                  @unique @map("referral_code")
  referredBy              String?                 @map("referred_by")
  createdAt               DateTime                @default(now()) @map("created_at")
  updatedAt               DateTime                @default(now()) @updatedAt @map("updated_at")
  accountNumber           String                  @unique @map("account_number")
  accountTier             String                  @default("basic") @map("account_tier")
  phone                   String?                 @map("phone")
  emailVerified           Boolean                 @default(false) @map("email_verified")
  emailVerifiedAt         DateTime?               @map("email_verified_at")
  phoneVerified           Boolean                 @default(false) @map("phone_verified")
  phoneVerifiedAt         DateTime?               @map("phone_verified_at")
  totpSecret              String?                 @map("totp_secret")
  twoFactorEnabled        Boolean                 @default(false) @map("two_factor_enabled")
  bvn                     String?                 @map("bvn")
  nin                     String?                 @map("nin")
  registrationStep        Int                     @default(1) @map("registration_step")
  registrationFeePaid     Boolean                 @default(false) @map("registration_fee_paid")
  registrationCompletedAt DateTime?               @map("registration_completed_at")
  bankAccountName         String?                 @map("bank_account_name")
  bankAccountNumber       String?                 @map("bank_account_number")
  bankCode                String?                 @map("bank_code")
  bankName                String?                 @map("bank_name")
  deletedAt               DateTime?               @map("deleted_at")
  email2faEnabled         Boolean                 @default(false) @map("email_2fa_enabled")
  auditLogs               AuditLog[]              @relation("AuditActor")
  circleAccounts          CircleAccount[]
  reviewedPayoutRequests  CirclePayoutRequest[]   @relation("ReviewedBy")
  circlePayoutRequests    CirclePayoutRequest[]   @relation("CirclePayoutRequestUser")
  conversationMembers     ConversationMember[]
  donations               Donation[]
  groupMembers            GroupMember[]
  jobApplications         JobApplication[]        @relation("Applicant")
  jobListings             JobListing[]
  kyc                     Kyc?
  loanRepayments          LoanRepayment[]
  loans                   Loan[]                  @relation("Borrower")
  marketplaceListings     MarketplaceListing[]
  marketplaceOffers       MarketplaceOffer[]      @relation("Offerer")
  sentMessages            Message[]
  notificationPreferences NotificationPreference?
  notifications           Notification[]
  referralEarnings        ReferralEarning[]
  referrals               Referral[]              @relation("Referrer")
  refreshTokens           RefreshToken[]
  ticketMessages          TicketMessage[]
  assignedTickets         Ticket[]                @relation("TicketAssignee")
  tickets                 Ticket[]                @relation("TicketUser")
  transactions            Transaction[]
  verificationTokens      VerificationToken[]
  virtualAccounts         VirtualAccount[]
  whatsappGroupMembers    WhatsappGroupMember[]

  @@map("users")
}

model AuditLog {
  id         String   @id @default(uuid())
  actorId    String?  @map("actor_id")
  actorEmail String?  @map("actor_email")
  action     String
  entity     String
  entityId   String?  @map("entity_id")
  metadata   String?
  ipAddress  String?  @map("ip_address")
  createdAt  DateTime @default(now()) @map("created_at")
  actor      User?    @relation("AuditActor", fields: [actorId], references: [id])

  @@index([actorId])
  @@index([entity])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

model Group {
  id             String        @id @default(uuid())
  name           String
  description    String?
  targetAmount   Float         @map("target_amount")
  currentAmount  Float         @default(0) @map("current_amount")
  memberCount    Int           @default(0) @map("member_count")
  cycleFrequency String        @map("cycle_frequency")
  status         String        @default("active")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @default(now()) @updatedAt @map("updated_at")
  deletedAt      DateTime?     @map("deleted_at")
  donations      Donation[]
  members        GroupMember[]

  @@map("groups")
}

model GroupMember {
  id        String    @id @default(uuid())
  groupId   String    @map("group_id")
  userId    String    @map("user_id")
  role      String    @default("member")
  joinedAt  DateTime  @default(now()) @map("joined_at")
  deletedAt DateTime? @map("deleted_at")
  group     Group     @relation(fields: [groupId], references: [id])
  user      User      @relation(fields: [userId], references: [id])

  @@unique([groupId, userId])
  @@map("group_members")
}

model Donation {
  id               String        @id @default(uuid())
  userId           String?       @map("user_id")
  type             String
  amount           Float?
  currency         String        @default("NGN")
  itemName         String?       @map("item_name")
  itemDescription  String?       @map("item_description")
  itemImage        String?       @map("item_image")
  itemCategory     String?       @map("item_category")
  itemCondition    String?       @map("item_condition")
  status           String        @default("pending")
  paymentProvider  String?       @map("payment_provider")
  paymentReference String?       @map("payment_reference")
  paymentUrl       String?       @map("payment_url")
  groupId          String?       @map("group_id")
  notes            String?
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @default(now()) @updatedAt @map("updated_at")
  deletedAt        DateTime?     @map("deleted_at")
  donorEmail       String?       @map("donor_email")
  donorName        String?       @map("donor_name")
  group            Group?        @relation(fields: [groupId], references: [id])
  user             User?         @relation(fields: [userId], references: [id])
  transactions     Transaction[]

  @@index([userId])
  @@index([groupId])
  @@index([paymentReference])
  @@map("donations")
}

model Transaction {
  id              String    @id @default(uuid())
  userId          String    @map("user_id")
  type            String
  amount          Float
  groupId         String?   @map("group_id")
  donationId      String?   @map("donation_id")
  reference       String    @unique
  status          String    @default("pending")
  description     String?
  createdAt       DateTime  @default(now()) @map("created_at")
  reversalOf      String?   @map("reversal_of")
  reversedAt      DateTime? @map("reversed_at")
  deletedAt       DateTime? @map("deleted_at")
  loanId          String?   @map("loan_id")
  metadata        Json?
  paymentProvider String?   @map("payment_provider")
  paymentUrl      String?   @map("payment_url")
  donation        Donation? @relation(fields: [donationId], references: [id])
  loan            Loan?     @relation(fields: [loanId], references: [id])
  user            User      @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([loanId])
  @@index([reversalOf])
  @@map("transactions")
}

model Referral {
  id             String            @id @default(uuid())
  referrerId     String            @map("referrer_id")
  referredUserId String            @map("referred_user_id")
  status         String            @default("pending")
  createdAt      DateTime          @default(now()) @map("created_at")
  deletedAt      DateTime?         @map("deleted_at")
  earnings       ReferralEarning[]
  referrer       User              @relation("Referrer", fields: [referrerId], references: [id])

  @@unique([referrerId, referredUserId])
  @@index([referrerId])
  @@map("referrals")
}

model ReferralEarning {
  id         String    @id @default(uuid())
  referralId String    @map("referral_id")
  referrerId String    @map("referrer_id")
  tier       String
  amount     Float
  status     String    @default("pending")
  createdAt  DateTime  @default(now()) @map("created_at")
  deletedAt  DateTime? @map("deleted_at")
  referral   Referral  @relation(fields: [referralId], references: [id])
  referrer   User      @relation(fields: [referrerId], references: [id])

  @@index([referrerId])
  @@map("referral_earnings")
}

model Kyc {
  id               String        @id @default(uuid())
  userId           String        @unique @map("user_id")
  idType           String        @map("id_type")
  idNumber         String        @map("id_number")
  selfieUrl        String?       @map("selfie_url")
  status           String        @default("pending")
  rejectionReason  String?       @map("rejection_reason")
  verifiedAt       DateTime?     @map("verified_at")
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @default(now()) @updatedAt @map("updated_at")
  idDocumentUrl    String?       @map("id_document_url")
  reviewedBy       String?       @map("reviewed_by")
  submittedAt      DateTime      @default(now()) @map("submitted_at")
  bvn              String?       @map("bvn")
  nin              String?       @map("nin")
  creditReport     Json?         @map("credit_report")
  verificationData Json?         @map("verification_data")
  verifiedName     String?       @map("verified_name")
  deletedAt        DateTime?     @map("deleted_at")
  level            Int           @default(1)
  user             User          @relation(fields: [userId], references: [id])
  auditLogs        KycAuditLog[]
  documents        KycDocument[]

  @@index([userId])
  @@index([status])
  @@map("kyc")
}

model KycDocument {
  id         String    @id @default(uuid())
  kycId      String    @map("kyc_id")
  fileUrl    String    @map("file_url")
  fileType   String    @map("file_type")
  fileName   String    @map("file_name")
  fileSize   Int       @map("file_size")
  purpose    String    @default("id_document")
  uploadedAt DateTime  @default(now()) @map("uploaded_at")
  deletedAt  DateTime? @map("deleted_at")
  kyc        Kyc       @relation(fields: [kycId], references: [id])

  @@index([kycId])
  @@map("kyc_documents")
}

model KycAuditLog {
  id          String    @id @default(uuid())
  kycId       String    @map("kyc_id")
  action      String
  oldStatus   String?   @map("old_status")
  newStatus   String?   @map("new_status")
  notes       String?
  performedBy String?   @map("performed_by")
  createdAt   DateTime  @default(now()) @map("created_at")
  deletedAt   DateTime? @map("deleted_at")
  kyc         Kyc       @relation(fields: [kycId], references: [id])

  @@index([kycId])
  @@index([createdAt])
  @@map("kyc_audit_logs")
}

model Conversation {
  id        String               @id @default(uuid())
  name      String?
  createdAt DateTime             @default(now()) @map("created_at")
  updatedAt DateTime             @default(now()) @updatedAt @map("updated_at")
  deletedAt DateTime?            @map("deleted_at")
  members   ConversationMember[]
  messages  Message[]

  @@map("conversations")
}

model ConversationMember {
  id             String       @id @default(uuid())
  conversationId String       @map("conversation_id")
  userId         String       @map("user_id")
  joinedAt       DateTime     @default(now()) @map("joined_at")
  deletedAt      DateTime?    @map("deleted_at")
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  user           User         @relation(fields: [userId], references: [id])

  @@unique([conversationId, userId])
  @@map("conversation_members")
}

model Message {
  id             String       @id @default(uuid())
  conversationId String       @map("conversation_id")
  senderId       String       @map("sender_id")
  text           String
  createdAt      DateTime     @default(now()) @map("created_at")
  deletedAt      DateTime?    @map("deleted_at")
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  sender         User         @relation(fields: [senderId], references: [id])

  @@index([conversationId])
  @@index([senderId])
  @@map("messages")
}

model WhatsappGroup {
  id          String                @id @default(uuid())
  name        String
  description String?
  circleName  String?               @map("circle_name")
  inviteLink  String?               @map("invite_link")
  memberCount Int                   @default(0) @map("member_count")
  pinned      Boolean               @default(false)
  createdAt   DateTime              @default(now()) @map("created_at")
  updatedAt   DateTime              @default(now()) @updatedAt @map("updated_at")
  deletedAt   DateTime?             @map("deleted_at")
  members     WhatsappGroupMember[]

  @@map("whatsapp_groups")
}

model WhatsappGroupMember {
  id        String        @id @default(uuid())
  groupId   String        @map("group_id")
  userId    String        @map("user_id")
  joinedAt  DateTime      @default(now()) @map("joined_at")
  deletedAt DateTime?     @map("deleted_at")
  group     WhatsappGroup @relation(fields: [groupId], references: [id])
  user      User          @relation(fields: [userId], references: [id])

  @@unique([groupId, userId])
  @@map("whatsapp_group_members")
}

model MarketplaceListing {
  id          String             @id @default(uuid())
  sellerId    String             @map("seller_id")
  title       String
  description String
  price       Float
  currency    String             @default("NGN")
  category    String
  condition   String
  imageUrl    String?            @map("image_url")
  status      String             @default("active")
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @default(now()) @updatedAt @map("updated_at")
  deletedAt   DateTime?          @map("deleted_at")
  seller      User               @relation(fields: [sellerId], references: [id])
  offers      MarketplaceOffer[]

  @@index([sellerId])
  @@index([status])
  @@index([category])
  @@map("marketplace_listings")
}

model MarketplaceOffer {
  id        String             @id @default(uuid())
  listingId String             @map("listing_id")
  offererId String             @map("offerer_id")
  amount    Float
  message   String?
  status    String             @default("pending")
  createdAt DateTime           @default(now()) @map("created_at")
  updatedAt DateTime           @default(now()) @updatedAt @map("updated_at")
  deletedAt DateTime?          @map("deleted_at")
  listing   MarketplaceListing @relation(fields: [listingId], references: [id])
  offerer   User               @relation("Offerer", fields: [offererId], references: [id])

  @@index([listingId])
  @@index([offererId])
  @@map("marketplace_offers")
}

model JobListing {
  id           String           @id @default(uuid())
  posterId     String           @map("poster_id")
  title        String
  description  String
  company      String?
  location     String
  jobType      String           @map("job_type")
  salaryMin    Float?           @map("salary_min")
  salaryMax    Float?           @map("salary_max")
  currency     String           @default("NGN")
  category     String
  status       String           @default("active")
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @default(now()) @updatedAt @map("updated_at")
  deletedAt    DateTime?        @map("deleted_at")
  applications JobApplication[]
  poster       User             @relation(fields: [posterId], references: [id])

  @@index([posterId])
  @@index([status])
  @@index([category])
  @@index([jobType])
  @@map("job_listings")
}

model JobApplication {
  id          String     @id @default(uuid())
  listingId   String     @map("listing_id")
  applicantId String     @map("applicant_id")
  resumeUrl   String?    @map("resume_url")
  status      String     @default("pending")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @default(now()) @updatedAt @map("updated_at")
  coverLetter String?
  deletedAt   DateTime?  @map("deleted_at")
  applicant   User       @relation("Applicant", fields: [applicantId], references: [id])
  listing     JobListing @relation(fields: [listingId], references: [id])

  @@unique([listingId, applicantId])
  @@index([listingId])
  @@index([applicantId])
  @@map("job_applications")
}

model Loan {
  id                 String             @id @default(uuid())
  borrowerId         String             @map("borrower_id")
  amount             Float
  interestRate       Float              @map("interest_rate")
  termMonths         Int                @map("term_months")
  monthlyPayment     Float              @map("monthly_payment")
  totalRepayment     Float              @map("total_repayment")
  purpose            String?
  status             String             @default("pending")
  approvedAt         DateTime?          @map("approved_at")
  disbursedAt        DateTime?          @map("disbursed_at")
  completedAt        DateTime?          @map("completed_at")
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @default(now()) @updatedAt @map("updated_at")
  disbursedAmount    Float?             @map("disbursed_amount")
  paidAmount         Float              @default(0) @map("paid_amount")
  principalPaid      Float              @default(0) @map("principal_paid")
  interestPaid       Float              @default(0) @map("interest_paid")
  outstandingBalance Float              @default(0) @map("outstanding_balance")
  nextDueDate        DateTime?          @map("next_due_date")
  processingFeeType  String?            @map("processing_fee_type")
  processingFeeValue Float?             @map("processing_fee_value")
  processingFee      Float?             @map("processing_fee")
  deletedAt          DateTime?          @map("deleted_at")
  disbursementMethod String?            @map("disbursement_method")
  disbursementStatus String?            @map("disbursement_status")
  disbursementRef    String?            @map("disbursement_ref")
  disbursementNote   String?            @map("disbursement_note")
  disbursedById      String?            @map("disbursed_by_id")
  repayments         LoanRepayment[]
  schedule           LoanScheduleItem[]
  borrower           User               @relation("Borrower", fields: [borrowerId], references: [id])
  transactions       Transaction[]

  @@index([borrowerId])
  @@index([status])
  @@map("loans")
}

model LoanScheduleItem {
  id            String    @id @default(uuid())
  loanId        String    @map("loan_id")
  installmentNo Int       @map("installment_no")
  dueDate       DateTime  @map("due_date")
  principal     Float
  interest      Float
  totalDue      Float     @map("total_due")
  principalPaid Float     @default(0) @map("principal_paid")
  interestPaid  Float     @default(0) @map("interest_paid")
  status        String    @default("pending")
  paidAt        DateTime? @map("paid_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  loan          Loan      @relation(fields: [loanId], references: [id], onDelete: Cascade)

  @@unique([loanId, installmentNo])
  @@index([loanId])
  @@index([status])
  @@map("loan_schedule_items")
}

model LoanRepayment {
  id         String   @id @default(uuid())
  loanId     String   @map("loan_id")
  borrowerId String   @map("borrower_id")
  amount     Float
  principal  Float
  interest   Float
  method     String   @default("wallet") @map("method")
  reference  String   @unique
  status     String   @default("completed")
  note       String?
  createdAt  DateTime @default(now()) @map("created_at")
  borrower   User     @relation(fields: [borrowerId], references: [id])
  loan       Loan     @relation(fields: [loanId], references: [id], onDelete: Cascade)

  @@index([loanId])
  @@index([borrowerId])
  @@map("loan_repayments")
}

model Circle {
  id                   String          @id @default(uuid())
  name                 String
  description          String?
  cycleType            String          @default("deposit") @map("cycle_type")
  amount               Float
  weeklyAmount         Float?          @map("weekly_amount")
  totalWeeks           Int?            @map("total_weeks")
  durationMonths       Int             @map("duration_months")
  interestRateAnnual   Float           @map("interest_rate_annual")
  maxAccountsPerUser   Int             @default(0) @map("max_accounts_per_user")
  autoPayout           Boolean         @default(false) @map("auto_payout")
  payoutMode           String          @default("auto") @map("payout_mode")
  blockPayoutOnDefault Boolean         @default(true) @map("block_payout_on_default")
  status               String          @default("active")
  deletedAt            DateTime?       @map("deleted_at")
  createdAt            DateTime        @default(now()) @map("created_at")
  updatedAt            DateTime        @default(now()) @updatedAt @map("updated_at")
  maxSubscribers       Int?            @map("max_subscribers")
  processingFeeType    String?         @map("processing_fee_type")
  processingFeeValue   Float?          @map("processing_fee_value")
  defaultPenaltyType   String          @default("percent") @map("default_penalty_type")
  defaultPenaltyValue  Float           @default(100) @map("default_penalty_value")
  initialWeeksCount    Int             @default(3) @map("initial_weeks_count")
  imageUrl             String?         @map("image_url")
  accounts             CircleAccount[]
  addons               CircleAddon[]

  @@map("circles")
}

model CircleAddon {
  id            String    @id @default(uuid())
  circleId      String    @map("circle_id")
  name          String
  description   String?
  quantity      Int       @default(1)
  estimatedCost Float     @map("estimated_cost")
  imageUrl      String?   @map("image_url")
  status        String    @default("active")
  deletedAt     DateTime? @map("deleted_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @default(now()) @updatedAt @map("updated_at")
  circle        Circle    @relation(fields: [circleId], references: [id], onDelete: Cascade)

  @@index([circleId])
  @@index([status])
  @@map("circle_addons")
}

model CircleAccount {
  id                      String                @id @default(uuid())
  circleId                String                @map("circle_id")
  userId                  String                @map("user_id")
  principalAmount         Float                 @map("principal_amount")
  interestEarned          Float                 @default(0) @map("interest_earned")
  totalWithdrawn          Float                 @default(0) @map("total_withdrawn")
  status                  String                @default("active")
  weeksContributed        Int                   @default(0) @map("weeks_contributed")
  weeksDefaulted          Int                   @default(0) @map("weeks_defaulted")
  lastContributionAttempt DateTime?             @map("last_contribution_attempt")
  startDate               DateTime              @map("start_date")
  maturityDate            DateTime              @map("maturity_date")
  lastInterestCalculation DateTime?             @map("last_interest_calculation")
  deletedAt               DateTime?             @map("deleted_at")
  createdAt               DateTime              @default(now()) @map("created_at")
  updatedAt               DateTime              @default(now()) @updatedAt @map("updated_at")
  processingFee           Float                 @default(0) @map("processing_fee")
  fundedByTxnRef          String?               @map("funded_by_txn_ref")
  reversedAt              DateTime?             @map("reversed_at")
  circle                  Circle                @relation(fields: [circleId], references: [id])
  user                    User                  @relation(fields: [userId], references: [id])
  contributions           CircleContribution[]
  defaults                CircleDefault[]
  interestLogs            CircleInterestLog[]
  payoutRequests          CirclePayoutRequest[]

  @@index([circleId])
  @@index([userId])
  @@index([status])
  @@map("circle_accounts")
}

model CircleContribution {
  id              String        @id @default(uuid())
  circleAccountId String        @map("circle_account_id")
  userId          String        @map("user_id")
  weekNumber      Int           @map("week_number")
  amount          Float
  type            String        @default("weekly")
  transactionId   String?       @map("transaction_id")
  createdAt       DateTime      @default(now()) @map("created_at")
  circleAccount   CircleAccount @relation(fields: [circleAccountId], references: [id])

  @@index([circleAccountId])
  @@index([userId])
  @@map("circle_contributions")
}

model CircleDefault {
  id              String        @id @default(uuid())
  circleAccountId String        @map("circle_account_id")
  userId          String        @map("user_id")
  weekNumber      Int           @map("week_number")
  amountDue       Float         @map("amount_due")
  clearanceAmount Float         @map("clearance_amount")
  status          String        @default("outstanding")
  clearedAt       DateTime?     @map("cleared_at")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @default(now()) @updatedAt @map("updated_at")
  circleAccount   CircleAccount @relation(fields: [circleAccountId], references: [id])

  @@index([circleAccountId])
  @@index([userId])
  @@index([status])
  @@map("circle_defaults")
}

model CircleInterestLog {
  id                     String        @id @default(uuid())
  circleAccountId        String        @map("circle_account_id")
  amount                 Float
  principalAtCalculation Float         @map("principal_at_calculation")
  annualRate             Float         @map("annual_rate")
  deletedAt              DateTime?     @map("deleted_at")
  calculatedAt           DateTime      @default(now()) @map("calculated_at")
  circleAccount          CircleAccount @relation(fields: [circleAccountId], references: [id])

  @@index([circleAccountId])
  @@index([calculatedAt])
  @@map("circle_interest_logs")
}

model CirclePayoutRequest {
  id                   String        @id @default(uuid())
  circleAccountId      String        @map("circle_account_id")
  userId               String        @map("user_id")
  amount               Float
  status               String        @default("pending")
  note                 String?
  reviewedById         String?       @map("reviewed_by_id")
  reviewedAt           DateTime?     @map("reviewed_at")
  clearedById          String?       @map("cleared_by_id")
  clearedAt            DateTime?     @map("cleared_at")
  clearanceNote        String?       @map("clearance_note")
  disbursementMethod   String?       @map("disbursement_method")
  disbursementStatus   String        @default("pending") @map("disbursement_status")
  disbursementRef      String?       @map("disbursement_ref")
  disbursementProofUrl String?       @map("disbursement_proof_url")
  disbursementNote     String?       @map("disbursement_note")
  disbursedById        String?       @map("disbursed_by_id")
  disbursedAt          DateTime?     @map("disbursed_at")
  createdAt            DateTime      @default(now()) @map("created_at")
  updatedAt            DateTime      @default(now()) @updatedAt @map("updated_at")
  circleAccount        CircleAccount @relation(fields: [circleAccountId], references: [id])
  reviewedBy           User?         @relation("ReviewedBy", fields: [reviewedById], references: [id])
  user                 User          @relation("CirclePayoutRequestUser", fields: [userId], references: [id])

  @@index([circleAccountId])
  @@index([userId])
  @@index([status])
  @@map("circle_payout_requests")
}

model NavigationItem {
  id        String           @id @default(uuid())
  label     String
  href      String           @unique
  icon      String
  badge     String?
  section   String           @default("")
  sortOrder Int              @default(0) @map("sort_order")
  isActive  Boolean          @default(true) @map("is_active")
  deletedAt DateTime?        @map("deleted_at")
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @default(now()) @updatedAt @map("updated_at")
  roles     RoleNavigation[]

  @@map("navigation_items")
}

model RoleNavigation {
  id               String         @id @default(uuid())
  role             String
  navigationItemId String         @map("navigation_item_id")
  sortOrder        Int            @default(0) @map("sort_order")
  deletedAt        DateTime?      @map("deleted_at")
  createdAt        DateTime       @default(now()) @map("created_at")
  navigationItem   NavigationItem @relation(fields: [navigationItemId], references: [id])

  @@unique([role, navigationItemId])
  @@index([role])
  @@map("role_navigation")
}

model VirtualAccount {
  id             String    @id @default(uuid())
  userId         String    @map("user_id")
  provider       String
  accountNumber  String    @map("account_number")
  bankName       String    @map("bank_name")
  bankCode       String?   @map("bank_code")
  currency       String    @default("NGN")
  reference      String    @unique
  providerRef    String?   @unique @map("provider_ref")
  isPermanent    Boolean   @default(true) @map("is_permanent")
  bvn            String?
  nin            String?
  status         String    @default("active")
  lastTransferAt DateTime? @map("last_transfer_at")
  deletedAt      DateTime? @map("deleted_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @default(now()) @updatedAt @map("updated_at")
  accountName    String?   @map("account_name")
  user           User      @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([provider])
  @@index([accountNumber])
  @@map("virtual_accounts")
}

model Notification {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  type      String
  title     String
  body      String
  data      String?
  channel   String    @default("in_app") @map("channel")
  status    String    @default("unread") @map("status")
  readAt    DateTime? @map("read_at")
  deletedAt DateTime? @map("deleted_at")
  createdAt DateTime  @default(now()) @map("created_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, status])
  @@index([createdAt])
  @@map("notifications")
}

model NotificationPreference {
  id        String   @id @default(uuid())
  userId    String   @unique @map("user_id")
  inApp     Boolean  @default(true) @map("in_app")
  email     Boolean  @default(true)
  sms       Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_preferences")
}

model VerificationToken {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  type        String
  channel     String    @map("channel")
  destination String?   @map("destination")
  code        String
  expiresAt   DateTime  @map("expires_at")
  consumedAt  DateTime? @map("consumed_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([code])
  @@map("verification_tokens")
}

model TicketCategory {
  id          String   @id @default(uuid())
  name        String
  description String?
  slug        String   @unique
  isActive    Boolean  @default(true) @map("is_active")
  position    Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")
  tickets     Ticket[]

  @@map("ticket_categories")
}

model Ticket {
  id          String          @id @default(uuid())
  subject     String
  description String
  status      String          @default("open")
  priority    String          @default("normal")
  categoryId  String?         @map("category_id")
  userId      String          @map("user_id")
  assigneeId  String?         @map("assignee_id")
  closedAt    DateTime?       @map("closed_at")
  deletedAt   DateTime?       @map("deleted_at")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @default(now()) @updatedAt @map("updated_at")
  messages    TicketMessage[]
  assignee    User?           @relation("TicketAssignee", fields: [assigneeId], references: [id])
  category    TicketCategory? @relation(fields: [categoryId], references: [id])
  user        User            @relation("TicketUser", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([assigneeId])
  @@index([status])
  @@index([priority])
  @@index([categoryId])
  @@index([createdAt])
  @@map("tickets")
}

model TicketMessage {
  id         String    @id @default(uuid())
  ticketId   String    @map("ticket_id")
  userId     String    @map("user_id")
  body       String
  isInternal Boolean   @default(false) @map("is_internal")
  deletedAt  DateTime? @map("deleted_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @default(now()) @updatedAt @map("updated_at")
  ticket     Ticket    @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@index([userId])
  @@map("ticket_messages")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}

model PrayerRequest {
  id           String    @id @default(uuid())
  authorName   String    @map("author_name")
  location     String?
  category     String
  request      String
  prayersCount Int       @default(0) @map("prayers_count")
  isActive     Boolean   @default(true) @map("is_active")
  deletedAt    DateTime? @map("deleted_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @default(now()) @updatedAt @map("updated_at")

  @@index([isActive])
  @@index([category])
  @@index([createdAt])
  @@map("prayer_requests")
}

model ImpactNarrative {
  id            String          @id @default(uuid())
  name          String
  age           Int
  country       String
  countryCode   String          @map("country_code")
  role          String
  cohort        String
  avatarUrl     String          @map("avatar_url")
  coverImageUrl String          @map("cover_image_url")
  headlineQuote String          @map("headline_quote")
  impactMetric  String          @map("impact_metric")
  impactLabel   String          @map("impact_label")
  longFormNarrative String[]    @map("long_form_narrative")
  sortOrder     Int             @default(0) @map("sort_order")
  isActive      Boolean         @default(true) @map("is_active")
  deletedAt     DateTime?       @map("deleted_at")
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @default(now()) @updatedAt @map("updated_at")

  gallery     ImpactGalleryPhoto[]
  timeline    ImpactTimelineMilestone[]

  @@index([isActive])
  @@index([sortOrder])
  @@map("impact_narratives")
}

model ImpactGalleryPhoto {
  id          String          @id @default(uuid())
  narrativeId String          @map("narrative_id")
  url         String
  caption     String
  tag         String
  sortOrder   Int             @default(0) @map("sort_order")
  deletedAt   DateTime?       @map("deleted_at")
  createdAt   DateTime        @default(now()) @map("created_at")

  narrative ImpactNarrative @relation(fields: [narrativeId], references: [id], onDelete: Cascade)

  @@index([narrativeId])
  @@index([sortOrder])
  @@map("impact_gallery_photos")
}

model ImpactTimelineMilestone {
  id          String          @id @default(uuid())
  narrativeId String          @map("narrative_id")
  year        String
  title       String
  description String
  tag         String
  status      String          @default("completed")
  sortOrder   Int             @default(0) @map("sort_order")
  deletedAt   DateTime?       @map("deleted_at")
  createdAt   DateTime        @default(now()) @map("created_at")

  narrative ImpactNarrative @relation(fields: [narrativeId], references: [id], onDelete: Cascade)

  @@index([narrativeId])
  @@index([sortOrder])
  @@map("impact_timeline_milestones")
}
